# ============================================
# 科创导师 - 环境变量示例
# 复制本文件为 .env 并填入真实值
# ============================================

# ===== 后端选择(优先级从上到下) =====
# 1. OpenAI 兼容中转站(推荐,本次用 yz.rs)
# 申请:联系中转站运营方拿 KEY
# 优先级最高,缺 KEY 才降级到豆包
OPENAI_COMPAT_BASE=https://api.yz.rs/v1
OPENAI_COMPAT_KEY=your_openai_key_here
OPENAI_COMPAT_MODEL=deepseek-v4-pro
# 可选:图片模型(若中转站支持,需另开通)
# OPENAI_COMPAT_IMAGE_MODEL=dall-e-3

# 2. 火山引擎豆包(原方案,留空)
# 申请:https://www.volcengine.com/product/doubao
# 必填,缺失则自动降级为 mock 响应
VOLC_ACCESS_KEY=
VOLC_MODEL=Doubao-Seed-1.6-flash

# 3. 火山 seedream 文生图(后续单独开通,留空)
# 申请:https://www.volcengine.com/product/seedream
# 申请后填 KEY,前端调 /api/ai/images 即可生成
# VOLC_SEEDREAM_KEY=
# VOLC_SEEDREAM_MODEL=doubao-seedream-3.0-t2i-250415

# 后端服务端口
PORT=3000

# 是否启用联网搜索(暂时占位,需要时由豆包 SDK 配置 tools)
ENABLE_WEB_SEARCH=false

# CORS 允许来源(逗号分隔,* 表示全部)
CORS_ORIGIN=http://localhost:5173

# ===== 评估路由可配置项 =====
# PromptX 导出的角色设定(可选,后续会接入)
# 格式:JSON 字符串,包含 persona 名称、prompt 片段、风格描述等
PROMPTX_PERSONA_JSON=
